<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- 
    Azure App Service F1 Tier Configuration
    
    CRITICAL: F1 tier has 60 minutes CPU time per day limit
    - This web.config optimizes for minimal CPU usage when idle
    - processPath points to the ASP.NET Core module
    - stdoutLogEnabled is false to reduce disk I/O and CPU overhead
    - hostingModel is set to OutOfProcess to reduce memory footprint
  -->
  <system.webServer>
    <handlers>
      <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
    </handlers>
    
    <aspNetCore 
      processPath="dotnet" 
      arguments=".\Velocify.API.dll" 
      stdoutLogEnabled="false" 
      stdoutLogFile=".\logs\stdout" 
      hostingModel="OutOfProcess">
      
      <!-- Environment variables for Azure App Service -->
      <environmentVariables>
        <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        <!-- 
          CPU Time Management for F1 Tier:
          - ASPNETCORE_ENVIRONMENT set to Production to disable detailed error pages
          - Serilog configured with 7-day log retention to manage disk space
          - Connection pooling (Min=2, Max=100) configured in DbContext to reuse connections
          - Health checks prevent unnecessary cold starts
          
          ALWAYS ON NOT AVAILABLE IN F1 TIER:
          - F1 tier does not support Always On feature
          - App will enter idle state after 20 minutes of inactivity
          - First request after idle will experience cold start (10-30 seconds)
          - Health checks configured with 5-minute interval to minimize cold starts
          - Upgrade to B1 tier (~$13/month) for Always On support
          
          CPU TIME QUOTA:
          - F1 tier has 60 minutes CPU time per day limit
          - Monitor usage: Azure Portal → App Service → Metrics → CPU Time
          - Set up alert at 50 minutes for 10-minute warning
          - If exceeded, app stops responding until midnight UTC quota reset
        -->
      </environmentVariables>
    </aspNetCore>
    
    <!-- Security headers -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="DENY" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
      </customHeaders>
    </httpProtocol>
    
    <!-- Compression to reduce bandwidth and improve response times -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />
    
    <!-- Rewrite rules for SPA fallback (if serving static files) -->
    <rewrite>
      <rules>
        <rule name="API Routes" stopProcessing="true">
          <match url="^api/.*" />
          <action type="None" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
